{
  "name": "attendance-system",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/frontend",
    "apps/backend"
  ],
  "scripts": {
    "dev:frontend": "npm run dev -w @attendance/frontend",
    "dev:backend": "npm run dev -w @attendance/backend",
    "build": "npm run build -w @attendance/frontend && npm run build -w @attendance/backend",
    "build:frontend": "npm run build -w @attendance/frontend",
    "build:backend": "npm run build -w @attendance/backend",
    "start:backend": "npm run start -w @attendance/backend",
    "typecheck:backend": "npm run typecheck -w @attendance/backend",
    "test": "npm run test -w @attendance/backend",
    "test:backend": "npm run test -w @attendance/backend",
    "migrate": "npm run migrate -w @attendance/backend",
    "migrate:status": "npm run migrate:status -w @attendance/backend",
    "migrate:baseline": "npm run migrate:baseline -w @attendance/backend",
    "seed:admin": "npm run seed:admin -w @attendance/backend"
  }
}
