{
  "name": "@attendance/backend",
  "version": "0.1.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "tsx src/db/migrate.ts",
    "migrate:status": "tsx src/db/migrate.ts status",
    "migrate:baseline": "tsx src/db/migrate.ts baseline",
    "migrate:list": "tsx src/db/migrate.ts list"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/multipart": "^8.3.1",
    "@fastify/rate-limit": "^9.1.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "mysql2": "^3.11.3",
    "nodemailer": "^8.0.6",
    "qrcode": "^1.5.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.7.5",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^4.1.8"
  }
}
