# Environment variables for the backend application
NODE_ENV=development
HOST=0.0.0.0
PORT=8080

# CORS — frontend origin(s) allowed to call /api with credentials.
# In production this MUST be set or browsers will refuse cookie auth.
#   blank          → dev fallback: http://localhost:5173 (prod: blocked)
#   single origin  → CORS_ORIGIN=https://attendance.example.com
#   multiple       → CORS_ORIGIN=https://app.example.com,https://staff.example.com
#   any            → CORS_ORIGIN=*    (only useful for public APIs; cookies
#                                       won't be sent across origins anyway)
CORS_ORIGIN=

# Database configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=drnadech_attendance_system
DB_CONNECTION_LIMIT=10

# SMTP configuration (for submission/check-in email delivery)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Attendance System
